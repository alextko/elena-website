{
  "cleanUrls": true,
  "redirects": [
    { "source": "/navigator", "destination": "/", "permanent": false },
    { "source": "/chat", "destination": "/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/invite/:code", "destination": "/invite/index.html" }
  ],
  "crons": [
    {
      "path": "/api/process-emails",
      "schedule": "*/15 * * * *"
    }
  ]
}
